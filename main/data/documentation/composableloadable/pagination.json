{"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"ComposableLoadable"}],"title":"Pagination"},"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ComposableLoadable\/documentation\/ComposableLoadable\/Pagination"},"abstract":[{"text":"When an API supports ","type":"text"},{"inlineContent":[{"text":"pagination","type":"text"}],"type":"emphasis"},{"text":", we mean that its response is a subset of items, but with a cursor to load the next “page” of items.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/ComposableLoadable\/documentation\/ComposableLoadable"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"inlineContent":[{"text":"Most applications which make use of an API to load a set of items because it cannot return all available items in a single request. To load more items, typically the application makes another request using a “pagination cursor”. This can go on indefinitely until all of the items have been loaded, and the API returns a nil pagination cursor.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"To that end this library contains a TCA compatible feature to support “infinite” scrolling and paginating items.","type":"text"}]},{"anchor":"Basics","level":3,"type":"heading","text":"Basics"},{"type":"paragraph","inlineContent":[{"text":"For example lets says that you get a list of messages from an API, something like:","type":"text"}]},{"syntax":"json","type":"codeListing","code":["{","  \"messages\": [","    \/* etc *\/","  ],","  \"nextPage\": \"<next-page-of-messages>\"","}"]},{"inlineContent":[{"type":"text","text":"You can get the next page of messages, by sending the value for "},{"code":"nextPage","type":"codeVoice"},{"type":"text","text":" as a query parameter in a subsequent request."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"By combining "},{"code":"LoadableState","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"PaginationFeature"},{"type":"text","text":" from this library, we can write a feature like this:"}],"type":"paragraph"},{"syntax":"swift","code":["struct Message: Identifiable {","  var id: String","}","@Reducer","struct MessagesFeature {","  struct State {","    \/\/ Wrap PaginationFeature state with LoadableState","    @LoadableStateWith<MessageRequest, PaginationFeature<Message>.State> var messages","  }","  enum Action {","    \/\/ The corresponding messages action","    case messages(","      \/\/ is a Loading Action","      LoadingAction<","        \/\/ generic over the kind of request sent to the `load` closure","        MessageRequest,","        \/\/ and the state\/action types","        PaginationFeature<Message>.State,","        PaginationFeature<Message>.Action","      >","    )","  }","  @Dependency(\\.api.loadMessages) var loadMessages","  var body: some ReducerOf<Self> {","    Reduce { state, action in","      \/\/ etc","      return .none","    }","    .loadable(\\.$messages, action: \\.messages) {","      PaginationFeature<Messages> { pageRequest in","        let response = try await loadMessages(cursor: pageRequest.cursor)","        return Page(","          next: response.nextPage,","          elements: response.messages","        )","      }","    } load: { request, state in","      let response = try await loadMessages()","      guard let firstMessage = response.messages.first else {","        fatalError(\"Handle no-results case\")","      }","      return PaginationFeature.State(","        selection: firstMessage.id,","        next: response.nextPage,","        elements: response.messages","      )","    }","  }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"In the above example, we ","type":"text"},{"inlineContent":[{"type":"text","text":"compose"}],"type":"emphasis"},{"type":"text","text":" "},{"type":"codeVoice","code":"PaginationFeature.State"},{"text":" inside the application feature. ","type":"text"},{"type":"codeVoice","code":"PaginationFeature"},{"type":"text","text":" is generic of the kind of object which is to be paginated, so "},{"type":"codeVoice","code":"Message"},{"text":" in this example.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Because we need to also fetch the initial page of messages without any pagination cursors, we ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"wrap"}]},{"text":" the ","type":"text"},{"type":"codeVoice","code":"PaginationFeature<Message>.State"},{"type":"text","text":" with "},{"code":"@LoadableState","type":"codeVoice"},{"type":"text","text":". So this means that the "},{"type":"codeVoice","code":".messages"},{"type":"text","text":" property itself is an optional, because initially it is in a "},{"code":".pending","type":"codeVoice"},{"type":"text","text":" state."}]},{"text":"Initial Load","anchor":"Initial-Load","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"When the feature performs the initial ","type":"text"},{"type":"codeVoice","code":".load"},{"text":", the closure calls the API, and constructs ","type":"text"},{"type":"codeVoice","code":"PaginationFeature.State"},{"type":"text","text":" from the response. In addition to the array of elements returned, the state value accepts "},{"type":"codeVoice","code":"previous"},{"type":"text","text":" and "},{"code":"next","type":"codeVoice"},{"type":"text","text":" pagination cursors. Here we define “next” to mean the values in the array which would be sorted after the current page of elements. If you API supports bi-directional pagination, the “previous” cursor is for those before the responses elements, however this value defaults to "},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}]},{"type":"heading","level":3,"text":"Selection","anchor":"Selection"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The non-optional "},{"code":"selection","type":"codeVoice"},{"type":"text","text":" property can be used to track which element (across all pages) is currently selected. Because this is not and optional value, it might be necessary to consider how to handle the “empty result” edge case. A good idea would be to have a separate enum based feature for the "},{"code":"ResultsFeature","type":"codeVoice"},{"text":" which includes a case for ","type":"text"},{"type":"codeVoice","code":".noResults"},{"text":".","type":"text"}]},{"anchor":"Pagination-Context","type":"heading","level":3,"text":"Pagination Context"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In some cases, it might be desirable to associate some additional metadata alongside your results. For example, perhaps the API also requires a “result-set-identifier”, or it’s necessary to keep hold of the total number of result elements. This is data which does not change or require mutation when performing pagination. In which case, create a specialised struct, which should conform to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableLoadable\/documentation\/ComposableLoadable\/PaginationContext"},{"text":" protocol, and set it as the ","type":"text"},{"code":"context","type":"codeVoice"},{"text":" property.","type":"text"}]},{"text":"Pagination","level":2,"anchor":"Pagination","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"To load another page or to change the selection, use the actions available via ","type":"text"},{"type":"codeVoice","code":"PaginationFeature.Action"},{"text":".","type":"text"}]},{"text":"Pagination Direction","type":"heading","anchor":"Pagination-Direction","level":3},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableLoadable\/documentation\/ComposableLoadable\/PaginationDirection"},{"text":" enum has four cases, ","type":"text"},{"code":".top","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":".bottom"},{"text":" for paging while vertically scrolling. And ","type":"text"},{"code":".leading","type":"codeVoice"},{"type":"text","text":", "},{"code":".trailing","type":"codeVoice"},{"text":" to enable “horizontal” paging, which will update the selection and also fetch a new page. The directions, ","type":"text"},{"type":"codeVoice","code":".top"},{"text":" and ","type":"text"},{"code":".leading","type":"codeVoice"},{"text":" both evaluate to showing or fetching elements which are before the current selection, while ","type":"text"},{"code":".bottom","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":".trailing"},{"type":"text","text":" show elements which are after the current selection. In other words, "},{"code":".top","type":"codeVoice"},{"type":"text","text":" would prepend new elements to the list, and "},{"type":"codeVoice","code":".bottom"},{"type":"text","text":" will append new elements."}],"type":"paragraph"},{"level":3,"type":"heading","text":"Load More","anchor":"Load-More"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableLoadable\/documentation\/ComposableLoadable\/PaginationLoadMore"},{"text":" is a SwiftUI view which can be placed in a scroll view to support infinite scrolling. If using a SwiftUI List or a ScrollView, we would expect to place a ","type":"text"},{"type":"codeVoice","code":"ForEach"},{"type":"text","text":" view followed by a "},{"identifier":"doc:\/\/ComposableLoadable\/documentation\/ComposableLoadable\/PaginationLoadMore","isActive":true,"type":"reference"},{"text":" view, to trigger loading of more elements.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/composableloadable\/pagination"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://ComposableLoadable/documentation/ComposableLoadable":{"kind":"symbol","type":"topic","url":"\/documentation\/composableloadable","role":"collection","title":"ComposableLoadable","identifier":"doc:\/\/ComposableLoadable\/documentation\/ComposableLoadable","abstract":[{"type":"text","text":"A micro-library to provide a “loading” capability to projects built with "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/pointfreeco\/swift-composable-architecture"},{"type":"text","text":" (TCA)."}]},"doc://ComposableLoadable/documentation/ComposableLoadable/PaginationLoadMore":{"type":"topic","navigatorTitle":[{"text":"PaginationLoadMore","kind":"identifier"}],"url":"\/documentation\/composableloadable\/paginationloadmore","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PaginationLoadMore"}],"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Trigger loading a new page when the view appears"}],"title":"PaginationLoadMore","identifier":"doc:\/\/ComposableLoadable\/documentation\/ComposableLoadable\/PaginationLoadMore"},"doc://ComposableLoadable/documentation/ComposableLoadable/PaginationDirection":{"abstract":[{"type":"text","text":"The direction of selection\/pagination"}],"navigatorTitle":[{"kind":"identifier","text":"PaginationDirection"}],"identifier":"doc:\/\/ComposableLoadable\/documentation\/ComposableLoadable\/PaginationDirection","role":"symbol","url":"\/documentation\/composableloadable\/paginationdirection","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PaginationDirection"}],"kind":"symbol","type":"topic","title":"PaginationDirection"},"doc://ComposableLoadable/documentation/ComposableLoadable/PaginationContext":{"navigatorTitle":[{"kind":"identifier","text":"PaginationContext"}],"identifier":"doc:\/\/ComposableLoadable\/documentation\/ComposableLoadable\/PaginationContext","abstract":[{"code":"PaginationContext","type":"codeVoice"},{"text":" allows framework consumers to associate","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"any"}],"type":"emphasis"},{"text":" additional information which might be required for pagination.","type":"text"}],"title":"PaginationContext","url":"\/documentation\/composableloadable\/paginationcontext","type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"PaginationContext","kind":"identifier"}],"role":"symbol","kind":"symbol"},"https://github.com/pointfreeco/swift-composable-architecture":{"titleInlineContent":[{"type":"text","text":"The Composable Architecture"}],"identifier":"https:\/\/github.com\/pointfreeco\/swift-composable-architecture","type":"link","title":"The Composable Architecture","url":"https:\/\/github.com\/pointfreeco\/swift-composable-architecture"}}}